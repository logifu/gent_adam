# Agent Architect Pro — Environment Variables
# Copy to .env and modify for your environment

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=aap
DB_PASSWORD=aap_dev_password
DB_NAME=agent_architect_pro

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Kafka (Redpanda) ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_CLIENT_ID=aap-service

# ── Temporal ──────────────────────────────────
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default

# ── OpenTelemetry ─────────────────────────────
OTEL_SERVICE_NAME=agent-architect-pro
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_ENABLED=true

# ── Auth ──────────────────────────────────────
AUTH_JWT_SECRET=dev-secret-change-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRY_MINUTES=30
AUTH_OIDC_ISSUER=http://localhost:8080/realms/aap

# ── MinIO (S3-compatible) ─────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aap-artifacts

# ── Application ───────────────────────────────
AAP_SERVICE_NAME=agent-architect-pro
AAP_ENVIRONMENT=development
AAP_DEBUG=true
